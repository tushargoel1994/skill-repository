{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "supplier_price_trend_by_criticality.py output",
  "description": "Requires --supplier and --component (both always). by_criticality has one dynamic key per component_criticality tier the target supplier actually has orders in for the given component (tiers the supplier never served aren't included). peer_* series are computed from all OTHER suppliers of the same component and criticality tier, not the whole dataset.",
  "type": "object",
  "$defs": {
    "monthly_price_point": {
      "type": "object",
      "properties": {
        "month": {"type": "string", "format": "date", "description": "First of the month, e.g. 2024-03-01."},
        "avg_price": {"type": "number"}
      },
      "required": ["month", "avg_price"],
      "additionalProperties": false
    },
    "criticality_entry": {
      "type": "object",
      "properties": {
        "target_po_count": {"type": "integer"},
        "peer_po_count": {"type": "integer"},
        "target_supplier_monthly_avg_price": {"type": "array", "items": {"$ref": "#/$defs/monthly_price_point"}},
        "peer_suppliers_monthly_avg_price": {"type": "array", "items": {"$ref": "#/$defs/monthly_price_point"}}
      },
      "required": ["target_po_count", "peer_po_count", "target_supplier_monthly_avg_price", "peer_suppliers_monthly_avg_price"],
      "additionalProperties": false
    }
  },
  "properties": {
    "filters": {
      "type": "object",
      "properties": {
        "component": {"type": "string"},
        "supplier": {"type": "string"},
        "criticality": {"type": "null", "description": "Always null — criticality is the breakdown dimension here, not a filter."}
      },
      "required": ["component", "supplier", "criticality"],
      "additionalProperties": false
    },
    "by_criticality": {
      "type": "object",
      "description": "Keys are component_criticality values (e.g. 'Critical', 'High', 'Standard') dynamic to the dataset.",
      "additionalProperties": {"$ref": "#/$defs/criticality_entry"}
    }
  },
  "required": ["filters", "by_criticality"],
  "additionalProperties": false
}
